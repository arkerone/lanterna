{
  "name": "@lanterna-profiler/cli",
  "version": "1.0.0",
  "description": "Agent-first Node.js CPU profiler — CLI",
  "type": "module",
  "bin": {
    "lanterna": "./bin/lanterna.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
