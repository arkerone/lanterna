{
  "name": "@lanterna-profiler/detectors",
  "version": "1.4.2",
  "description": "Lanterna default detector pack — blocking I/O, GC, event loop, deopts, hotspots",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.map",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .turbo .tsbuildinfo"
  },
  "dependencies": {
    "@lanterna-profiler/core": "^1.6.1"
  },
  "devDependencies": {
    "zod": "^4.4.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arkerone/lanterna.git",
    "directory": "packages/detectors"
  },
  "license": "MIT"
}
