{
  "name": "@lanterna/core",
  "version": "0.1.0",
  "description": "Agent-first Node.js CPU profiler — headless capture + analysis primitives",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
