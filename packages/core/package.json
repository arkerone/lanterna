  "scripts": {
    "prebuild": "node scripts/generate-version.js",
    "build": "tsc -b && node scripts/copy-assets.js",
    "dev": "tsc -b --watch"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
