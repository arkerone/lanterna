{
  "name": "@lanterna-profiler/core",
  "version": "1.7.1",
  "description": "Agent-first Node.js CPU, memory & async profiler — headless capture + analysis primitives",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.map",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-version.js",
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .turbo .tsbuildinfo src/report/version.generated.ts"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.128.0",
    "pino": "^10.3.1",
    "zod": "^4.4.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arkerone/lanterna.git",
    "directory": "packages/core"
  },
  "license": "MIT"
}
