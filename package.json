{
  "name": "lanterna",
  "version": "0.1.0",
  "description": "Agent-first Node.js CPU profiler — structured, semantically enriched JSON output for AI consumption",
  "type": "module",
  "bin": {
    "lanterna": "./bin/lanterna.js"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./analysis": {
      "types": "./dist/analysis/index.d.ts",
      "default": "./dist/analysis/index.js"
    },
    "./report": {
      "types": "./dist/report/index.d.ts",
      "default": "./dist/report/index.js"
    },
    "./report/types": {
      "types": "./dist/report/types.d.ts",
      "default": "./dist/report/types.js"
    }
  },
  "files": [
    "README.md",
    "assets",
    "bin",
    "dist",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arkerone/lanterna"
  },
  "bugs": {
    "url": "https://github.com/arkerone/lanterna/issues"
  },
  "homepage": "https://github.com/arkerone/lanterna#readme",
  "scripts": {
    "build": "node scripts/generate-version.js && tsc && node scripts/copy-assets.js",
    "test": "rm -rf dist dist-test && node scripts/generate-version.js && npm run build && tsc -p tsconfig.test.json && node scripts/copy-assets.js --dest=dist-test/src && node --test dist-test/test/**/*.test.js",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "keywords": [
    "profiler",
    "cpu",
    "nodejs",
    "v8",
    "ai-agent",
    "llm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^24.12.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
